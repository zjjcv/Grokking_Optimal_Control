{
    "figure": {
        "figsize": [10, 5],
        "dpi": 150
    },
    "line": {
        "linewidth": 2.5,
        "train_linestyle": "--",
        "test_linestyle": "-"
    },
    "color": {
        "accuracy": "tab:blue",
        "loss": "tab:red"
    },
    "grid": {
        "alpha": 0.3
    },
    "axis": {
        "x_scale": "log",
        "acc_ylim": [-0.05, 1.05]
    },
    "legend": {
        "loc": "lower center",
        "bbox_to_anchor": [0.5, 0.0],
        "ncol": 4,
        "frameon": false,
        "fontsize": 11
    }
}
